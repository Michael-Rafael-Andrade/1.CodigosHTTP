<h1 class="mb-4">{{titulo_pagina}}</h1>

{{#each erros}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{msg}}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{{/each}}

<div class="card">
    <div class="card-body">
        <form action="/livros/criar" method="POST">
            
            <div class="mb-3">
                <label for="titulo" class="form-label">Título do Livro</label>
                <input type="text" class="form-control" id="titulo" name="titulo" value="{{old.titulo}}" required>
            </div>

            <div class="mb-3">
                <label for="autor" class="form-label">Autor</label>
                <input type="text" class="form-control" id="autor" name="autor" value="{{old.autor}}" required>
            </div>

            <div class="mb-3">
                <label for="id_categoria" class="form-label">Categoria</label>
                <select class="form-select" id="id_categoria" name="id_categoria" required>
                    <option value="">Selecione uma categoria...</option>
                    {{#each categorias}}
                        <option value="{{id}}" {{#if (eq id ../old.id_categoria)}}selected{{/if}}>{{nome}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success">Salvar Livro</button>
                <a href="/" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>